{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:cf": "BUILD_TARGET=cloudflare vite build",
    "build:netlify": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy:netlify": "npm run build:netlify && netlify deploy --prod --dir=dist",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "@netlify/edge-functions": "^2.11.1"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
